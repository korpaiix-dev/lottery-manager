{
  "name": "lottery-manager",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "check": "node --check server.js && node --check app.js",
    "smoke": "node scripts/e2e-smoke.mjs",
    "qa:deep": "node scripts/qa-deep.mjs",
    "payouts:defaults": "node scripts/set-default-payouts.mjs",
    "regression": "node scripts/regression-2026-05-22.mjs",
    "regression:line": "node scripts/regression-line-parser.mjs",
    "predeploy": "npm run check && npm test && npm run smoke",
    "commit-safe": "npm run check && git status",
    "test": "node --test \"tests/**/*.test.mjs\" \"providers/scraper/parsers/__tests__/**/*.test.mjs\"",
    "test:parsers": "node --test \"providers/scraper/parsers/__tests__/**/*.test.mjs\"",
    "test:integration": "node --test tests/integration.test.mjs"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "express": "^5.1.0",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "promptpay-qr": "^0.5.0",
    "puppeteer-core": "^25.1.0",
    "qrcode": "^1.5.4"
  }
}
